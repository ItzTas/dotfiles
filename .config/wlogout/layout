{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Lock",
    "keybind" : "l"
}

{
    "label" : "logout",
    "action" : "notify-send 'Logging out...'&hyprshutdown",
    "text" : "Logout",
    "keybind" : "e"
}

{
    "label" : "suspend",
    "action" : "hyprlock -f & systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}

{
    "label": "shutdown",
    "action": "hyprshutdown -t 'Shutting down...' --post-cmd 'systemctl poweroff'",
    "text": "Shutdown",
    "keybind": "s"
}

{
    "label" : "hibernate",
    "action" : "systemctl hibernate",
    "text" : "Hibernate",
    "keybind" : "h"
}

{
    "label": "reboot",
    "action": "hyprshutdown -t 'Restarting...' --post-cmd 'systemctl reboot'",
    "text": "Reboot",
    "keybind": "r"
}
