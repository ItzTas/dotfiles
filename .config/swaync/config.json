{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 380,
  "control-center-height": 750,
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 2,
  "control-center-margin-right": 2,
  "control-center-margin-left": 0,
  "notification-window-width": 400,
  "notification-body-image-height": 160,
  "notification-body-image-width": 200,
  "timeout-low": 4,
  "timeout": 6,
  "timeout-critical": 10,
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "relative-timestamps": true,
  "scripts": {
    "debug": {
      "exec": "bash \"$HOME/.config/swaync/scripts/debug.sh\"",
      "app-name": ".*"
    }
  },
  "notification-visibility": {
    "thunderbird-imap.gmail.com-conection-fail-transient": {
      "state": "transient",
      "app-name": "[Tt]hunderbird",
      "body": "Unable to connect to(.*)? imap\\.gmail\\.com(.*)"
    },
    "spotify-transient": {
      "state": "transient",
      "app-name": "[Ss]potify"
    },
    "arch-update-transient": {
      "state": "transient",
      "app-name": "[Aa]rch-[Uu]pdate"
    },
    "proton-mail-bridge-transient": {
      "state": "transient",
      "app-name": "[Pp]roton [Mm]ail [Bb]ridge"
    },
    "zen-proton-vpn-transient": {
      "state": "transient",
      "app-name": "Zen",
      "summary": "Proton VPN",
      "urgency": "Low"
    },
    "__transient": {
      "state": "transient",
      "app-name": "__transient"
    }
  },
  "widgets": [
    "dnd",
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": " Notifications",
      "clear-all-button": true,
      "button-text": " 󰎟 "
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 1,
      "text": " "
    },
    "mpris": {},
    "volume": {
      "label": "󰕾",
      "show-per-app": true
    },
    "buttons-grid": {
      "actions": []
    }
  }
}
