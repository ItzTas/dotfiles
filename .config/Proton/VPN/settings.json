{
    "protocol": "wireguard",
    "killswitch": 0,
    "custom_dns": {
        "enabled": false,
        "ip_list": []
    },
    "ipv6": true,
    "anonymous_crash_reports": false,
    "features": {
        "netshield": 0,
        "moderate_nat": false,
        "vpn_accelerator": true,
        "port_forwarding": false,
        "split_tunneling": {
            "enabled": true,
            "mode": "exclude",
            "config_by_mode": {
                "exclude": {
                    "mode": "exclude",
                    "app_paths": [
                        "/usr/bin/steam",
                        "/opt/Bruno/bruno",
                        "/usr/bin/steam",
                        "/usr/bin/discord",
                        "/opt/Heroic/heroic",
                        "/usr/bin/flatpak run --branch=master --arch=x86_64 --command=hytale-launcher-wrapper com.hypixel.HytaleLauncher",
                        "/usr/bin/steam",
                        "/usr/bin/lutris",
                        "/usr/bin/steam",
                        "/usr/bin/steam",
                        "/usr/bin/steam",
                        "/usr/bin/steam",
                        "/usr/bin/steam",
                        "/usr/bin/flatpak run --branch=stable --arch=x86_64 --command=sober --file-forwarding org.vinegarhq.Sober --",
                        "/usr/bin/spotify",
                        "/usr/bin/steam",
                        "/usr/bin/steam",
                        "/usr/bin/steam",
                        "/usr/bin/steam",
                        "/usr/bin/vesktop",
                        "/opt/zen-browser-bin/zen-bin"
                    ],
                    "ip_ranges": []
                },
                "include": {
                    "mode": "include",
                    "app_paths": [],
                    "ip_ranges": []
                }
            }
        }
    }
}