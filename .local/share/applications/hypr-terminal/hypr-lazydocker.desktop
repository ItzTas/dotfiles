[Desktop Entry]
Name=LazyDocker Hypr
Comment=Docker UI in Hyprland
# Old syntax (hyprlang dispatcher):
# Exec=hyprctl dispatch exec "[no_blur 0; float; size (monitor_w*0.90) (monitor_h*0.80); center] kitty -o cursor_trail=0 -o background_opacity=0.65 -e lazydocker"
Exec=hyprctl eval 'hl.exec_cmd("kitty -o cursor_trail=0 -o background_opacity=0.65 -e lazydocker", { float = true, no_anim = true, no_blur = true, size = { "(monitor_w * 0.9)", "(monitor_h * 0.8)" }, center = true })'
Icon=utilities-terminal
Terminal=false
Type=Application
Categories=System;Utility;